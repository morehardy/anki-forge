{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "required": [
    "id",
    "version",
    "emit_apkg",
    "materialize_staging",
    "media_resolution_mode",
    "unresolved_asset_behavior",
    "fingerprint_mode"
  ],
  "additionalProperties": false,
  "properties": {
    "id": {
      "type": "string",
      "minLength": 1
    },
    "version": {
      "type": "string",
      "minLength": 1
    },
    "emit_apkg": {
      "type": "boolean"
    },
    "materialize_staging": {
      "type": "boolean"
    },
    "media_resolution_mode": {
      "enum": ["inline-only"]
    },
    "unresolved_asset_behavior": {
      "enum": ["fail", "warn"]
    },
    "fingerprint_mode": {
      "enum": ["canonical"]
    }
  }
}
