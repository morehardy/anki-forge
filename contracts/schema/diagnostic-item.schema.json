{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "required": ["level", "code", "path", "message"],
  "additionalProperties": false,
  "properties": {
    "level": {
      "enum": ["warning", "error"]
    },
    "code": {
      "type": "string",
      "minLength": 1
    },
    "path": {
      "type": "string",
      "minLength": 1
    },
    "message": {
      "type": "string",
      "minLength": 1
    }
  }
}
