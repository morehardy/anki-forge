{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "required": ["codes"],
  "additionalProperties": false,
  "properties": {
    "codes": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "status", "summary"],
        "additionalProperties": false,
        "properties": {
          "id": {
            "type": "string",
            "minLength": 1
          },
          "status": {
            "enum": ["active", "deprecated", "removed"]
          },
          "summary": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    }
  }
}
