{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "required": ["id", "version", "default_mode", "override_modes", "require_reason_code"],
  "additionalProperties": false,
  "properties": {
    "id": {
      "type": "string",
      "minLength": 1
    },
    "version": {
      "type": "string",
      "minLength": 1
    },
    "default_mode": {
      "enum": ["deterministic"]
    },
    "override_modes": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "enum": ["external", "random"]
      }
    },
    "require_reason_code": {
      "type": "boolean"
    }
  }
}
