          "type": "string",
          "minLength": 1
        },
        "error_registry": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "compatibility": {
      "type": "object",
      "required": ["public_axis"],
      "additionalProperties": false,
      "properties": {
        "public_axis": {
          "const": "bundle_version"
        }
      }
    },
    "assets": {
      "type": "object",
      "required": [
        "manifest_schema",
        "version_policy",
        "identity_policy_schema",
