{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "$defs": {
    "diagnostic_item": {
      "type": "object",
      "required": ["level", "code", "summary"],
      "additionalProperties": false,
      "properties": {
        "level": {
          "enum": ["info", "warning", "error"]
        },
        "code": {
          "type": "string",
          "minLength": 1
        },
        "summary": {
          "type": "string",
          "minLength": 1
        }
      }
    }
  },
  "required": ["kind", "status", "items"],
  "additionalProperties": false,
  "properties": {
    "kind": {
      "const": "normalization-diagnostics"
    },
    "status": {
      "enum": ["valid", "invalid", "error"]
    },
    "items": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/diagnostic_item"
      }
    }
  }
}
