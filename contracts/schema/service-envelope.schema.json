{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "required": ["kind", "request_id", "status"],
  "additionalProperties": false,
  "properties": {
    "kind": {
      "const": "service-envelope"
    },
    "request_id": {
      "type": "string",
      "minLength": 1
    },
    "status": {
      "enum": ["ok", "error"]
    }
  }
}
